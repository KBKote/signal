    "@types/he": "^1.2.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "@types/three": "^0.183.1",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
