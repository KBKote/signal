    "@supabase/supabase-js": "^2.103.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "he": "^1.2.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "openai": "^6.34.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rss-parser": "^3.13.0",
    "sanitize-html": "^2.17.2",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "web-push": "^3.6.7"
  },
