{
  "name": "signal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--dns-result-order=ipv4first' next dev",
    "dev:fresh": "rm -rf .next && NODE_OPTIONS='--dns-result-order=ipv4first' next dev",
    "build": "next build --webpack",
    "start": "NODE_OPTIONS='--dns-result-order=ipv4first' next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "tunnel": "cloudflared tunnel --url http://localhost:3000",
    "mcp:playwright:sse": "npx -y @playwright/mcp@latest --port 4173 --host 127.0.0.1 --executable-path \"/Applications/Brave Browser.app/Contents/MacOS/Brave Browser\" --user-data-dir \"/Users/karimb/Library/Caches/playwright-mcp-brave-profile\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "@radix-ui/react-slot": "^1.2.4",
